{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iureditor",
  "version": "1.5.4",
  "identifier": "com.ellaguno.iureditor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGMUI0OEUxNjg1NjE1MjUKUldRbEZWWm80VWdiajlpRzB5WFRKY0RFZ01VVGN0TVMrV01LQjZWTUNTa3JsV0VoMFRWQTlmbmUK",
      "endpoints": [
        "https://github.com/ellaguno/iureditor/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "iureditor",
        "width": 1100,
        "height": 780,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["appimage", "deb", "nsis", "app", "dmg"],
    "category": "Productivity",
    "shortDescription": "Editor WYSIWYG de Markdown",
    "longDescription": "Editor WYSIWYG de Markdown con diagramas Mermaid en vivo y exportación a PDF y DOCX.",
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown",
        "description": "Documento Markdown",
        "mimeType": "text/markdown",
        "role": "Editor"
      }
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "./iureditor.desktop"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
